---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import {
  site,
  skillGroups,
  experience,
  education,
  certifications,
  awards,
} from '../data/site';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const initials = site.name
  .split(' ')
  .map((n) => n[0])
  .join('');
---

<BaseLayout>
  <!-- Hero -->
  <section class="hero">
    <div class="avatar">{initials}</div>
    <div>
      <h1>{site.name}</h1>
      <p class="role">
        {site.role}<span class="dot">·</span>{site.location}
      </p>
    </div>
    <div class="hero-lead">
      <p class="lead">{site.tagline}</p>
      <div class="availability">
        <span class="pulse"></span> Open to iOS &amp; software engineering roles
      </div>
      <div class="socials">
        <a href={site.socials.github}>GitHub</a>
        <a href={site.socials.linkedin}>LinkedIn</a>
        <a href={site.socials.leetcode}>LeetCode</a>
        <a href={site.socials.email}>Email</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about">
    <p class="section-title">About</p>
    <p class="muted">{site.summary}</p>
  </section>

  <!-- Skills -->
  <section id="skills">
    <p class="section-title">Skills</p>
    {
      skillGroups.map((group) => (
        <div class="skill-group">
          <div class="label">{group.label}</div>
          <div class="chips">
            {group.items.map((s) => (
              <span class="chip">{s}</span>
            ))}
          </div>
        </div>
      ))
    }
  </section>

  <!-- Experience -->
  <section id="experience">
    <p class="section-title">Experience</p>
    {
      experience.map((job) => (
        <div class="card">
          <div class="top">
            <div>
              <h3>{job.company}</h3>
              <div class="role-line">{job.role}</div>
              <div class="sub">
                {job.employer ? `${job.employer} · ` : ''}
                {job.project}
                {job.location ? ` · ${job.location}` : ''}
              </div>
            </div>
            <span class="period">{job.period}</span>
          </div>
          <ul>
            {job.highlights.map((h) => (
              <li>{h}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </section>

  <!-- Education -->
  <section id="education">
    <p class="section-title">Education</p>
    {
      education.map((e) => (
        <div class="card">
          <div class="top">
            <div>
              <h3>{e.school}</h3>
              <div class="role-line">{e.degree}</div>
              {e.detail && <div class="sub">{e.detail}</div>}
            </div>
            <span class="period">{e.period}</span>
          </div>
        </div>
      ))
    }
  </section>

  <!-- Certifications -->
  <section id="certifications">
    <p class="section-title">Certifications</p>
    <div class="grid-2">
      {
        certifications.map((c) => (
          <div class="card">
            <h3 style="font-size: 1rem;">{c.name}</h3>
            <div class="sub">
              {c.issuer} · {c.year}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Awards -->
  <section id="awards">
    <p class="section-title">Honors &amp; Awards</p>
    <ul class="clean">
      {awards.map((a) => <li>{a}</li>)}
    </ul>
  </section>

  <!-- Latest posts -->
  <section id="writing">
    <p class="section-title">Latest Writing</p>
    {
      posts.length === 0 ? (
        <p class="muted">No posts yet — check back soon.</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a class="title" href={`/blog/${post.id}/`}>
                {post.data.title}
              </a>
              <div class="post-meta">{fmt(post.data.pubDate)}</div>
              <p class="post-desc">{post.data.description}</p>
            </li>
          ))}
        </ul>
      )
    }
    <p style="margin-top: 18px;"><a href="/blog">All posts →</a></p>
  </section>
</BaseLayout>
